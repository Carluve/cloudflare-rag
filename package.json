{
  "name": "cloudflare-rag",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "deploy": "npm run build && wrangler deploy",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "wrangler dev",
    "typecheck": "tsc",
    "typegen": "wrangler types",
    "preview": "npm run build && wrangler dev",
    "cf-typegen": "wrangler types",
    "migrate:local": "npx drizzle-kit generate && wrangler d1 migrations apply cloudflare-rag --local",
    "migrate": "npx drizzle-kit generate && wrangler d1 migrations apply cloudflare-rag --remote"
  },
  "dependencies": {
    "@cloudflare/ai-utils": "^1.0.1",
    "@langchain/core": "^0.2.28",
    "@langchain/textsplitters": "^0.0.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@remix-run/cloudflare": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "fetch-event-stream": "^0.1.6",
    "framer-motion": "^12.36.0",
    "isbot": "^5.1.36",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone-esm": "^15.2.0",
    "react-markdown": "^9.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ulidx": "^2.4.1",
    "unpdf": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@remix-run/dev": "^2.17.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
